{
  "name": "@despia/powersync",
  "version": "1.1.0",
  "description": "Despia Native SDK for offline-first local SQLite + real-time PowerSync sync in web-native apps",
  "author": "Despia",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/despia-native/despia-powersync.git"
  },
  "homepage": "https://github.com/despia-native/despia-powersync#readme",
  "bugs": {
    "url": "https://github.com/despia-native/despia-powersync/issues"
  },
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/types/index.d.ts",
  "browser": "./dist/esm/index.mjs",
  "unpkg": "./dist/umd/despia-powersync.min.js",
  "jsdelivr": "./dist/umd/despia-powersync.min.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/esm/index.mjs"
      },
      "require": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/cjs/index.cjs"
      }
    },
    "./powersync.js": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/esm/powersync.js"
    },
    "./umd": {
      "default": "./dist/umd/despia-powersync.min.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "despia",
    "despia-native",
    "web-native",
    "sqlite",
    "powersync",
    "sync",
    "realtime",
    "offline-first",
    "local-database",
    "webview",
    "native-bridge"
  ],
  "scripts": {
    "build": "npx tsup && npx tsc --emitDeclarationOnly --declaration --declarationMap --outDir dist/types",
    "dev": "npx tsup --watch",
    "typecheck": "npx tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build",
    "release:pack": "npm pkg fix && npm run typecheck && npm run build && npm pack --dry-run",
    "release:npm": "npm publish --access public",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
